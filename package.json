{
  "name": "railway",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node --test tests/**/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"scripts/*.mjs\" --test-coverage-include=\"scripts/lib/*.mjs\" --test-coverage-exclude=\"scripts/misc-cli-utils.mjs\" --test tests/**/*.test.mjs",
    "test:coverage:check": "node --experimental-test-coverage --test-coverage-include=\"scripts/*.mjs\" --test-coverage-include=\"scripts/lib/*.mjs\" --test-coverage-exclude=\"scripts/misc-cli-utils.mjs\" --test-coverage-lines=90 --test-coverage-functions=90 --test tests/**/*.test.mjs",
    "readme:footer": "node scripts/replace-readme-footer.mjs",
    "git:sync:submodules": "node scripts/sync-submodules-git.mjs",
    "templates:sync": "node scripts/sync-railway-template-drafts.mjs",
    "templates:sync:apply": "node scripts/sync-railway-template-drafts.mjs --apply --recreate-missing",
    "templates:verify": "node scripts/verify-railway-template-drafts.mjs",
    "templates:verify:json": "node scripts/verify-railway-template-drafts.mjs --json",
    "templates:publish": "node scripts/publish-railway-template-drafts.mjs",
    "templates:publish:apply": "node scripts/publish-railway-template-drafts.mjs --apply",
    "templates:display-names": "node scripts/apply-railway-template-display-names.mjs",
    "templates:display-names:apply": "node scripts/apply-railway-template-display-names.mjs --apply",
    "marketplace:queries:generate": "node scripts/generate-railway-marketplace-check-queries.mjs",
    "marketplace:search": "node scripts/railway-template-marketplace-search.mjs",
    "marketplace:search:json": "node scripts/railway-template-marketplace-search.mjs --json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.2",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1"
  }
}
